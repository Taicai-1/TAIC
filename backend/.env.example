# Environment variables for development
# Copy this file to .env and replace ALL placeholder values before use

OPENAI_API_KEY=sk-replace-with-your-openai-key
OPENAI_MODEL=gpt-4-1106-preview
OPENAI_MAX_TOKENS=128000
JWT_SECRET_KEY=replace-with-a-random-secret-min-32-chars
DATABASE_URL=postgresql://devuser:CHANGE_THIS_PASSWORD@localhost:5432/applydidb
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=europe-west1

# Neo4j Knowledge Graph (optional)
NEO4J_URI=neo4j+ssc://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-your-neo4j-password

# Docker Compose database (used by docker-compose.yml)
POSTGRES_USER=devuser
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=applydidb

# Perplexity (optional – for recherche_live agents or llm_provider=perplexity)
PERPLEXITY_API_KEY=pplx-replace-with-your-perplexity-key
PERPLEXITY_MODEL=perplexity:sonar
